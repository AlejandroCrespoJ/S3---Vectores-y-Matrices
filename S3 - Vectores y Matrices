#include <stdio.h>

int main(){

     int notas[5][3];
    float promedioEstudiante[5];
    float promedioAsignatura[3];
    int altaEstudiante[5], bajaEstudiante[5];
    int altaAsignatura[3], bajaAsignatura[3];
    int aprobados[3] = {0, 0, 0};
    int reprobados[3] = {0, 0, 0};
    int i, j; 



       printf("     Registro de Calificaciones     \n");
    printf("El programa registra 5 estudiantes y 3 asignaturas.\n\n");

    for (i = 0; i < 5; i++) {
        printf("Estudiante %d\n", i + 1);}
        for (j = 0; j < 3; j++) {
            do{
                
                printf("Ingrese la nota de la asignatura %d (0 a 10): ", j + 1);
                scanf("%d", &notas[i][j]);

                if (notas[i][j] < 0 || notas[i][j] > 10) {
                    printf("Nota invalida. Debe ingresar un valor entre 0 y 10.\n");
                }

            } while (notas[i][j] < 0 || notas[i][j] > 10);

        }
        printf("\n");

        
    for (i = 0; i < 5; i++) {
        int suma = 0;
       altaEstudiante[i] = notas[i][0];
        bajaEstudiante[i] = notas[i][0];

       for (j = 0; j < 3; j++) {
            suma = suma + notas[i][j];

            if (notas[i][j] > altaEstudiante[i]) {
                altaEstudiante[i] = notas[i][j];
            }

            if (notas[i][j] < bajaEstudiante[i]) {
                bajaEstudiante[i] = notas[i][j];
            }
        }

       promedioEstudiante[i] = suma / 3.0;
    }

    for (j = 0; j < 3; j++) {
        int suma = 0;
        altaAsignatura[j] = notas[0][j];
        bajaAsignatura[j] = notas[0][j];

        for (i = 0; i < 5; i++) {
            suma = suma + notas[i][j];

            if (notas[i][j] > altaAsignatura[j]) {
                altaAsignatura[j] = notas[i][j];
            }

            if (notas[i][j] < bajaAsignatura[j]) {
                bajaAsignatura[j] = notas[i][j];
            }

            if (notas[i][j] >= 6) {
                aprobados[j] = aprobados[j] + 1;
            } else {
                reprobados[j] = reprobados[j] + 1;
            }
        }

        promedioAsignatura[j] = suma / 5.0;
    }

    
    }






}




